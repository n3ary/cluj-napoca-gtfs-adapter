{
  "name": "cluj-napoca-gtfs-adapter",
  "version": "0.1.2",
  "private": false,
  "type": "module",
  "description": "Reconciled GTFS Schedule publisher for Cluj-Napoca (CTP) — combines Transitous seed, Tranzy.ai live static API, and CTP CSV timetables into the most complete, error-free feed.",
  "main": "src/cli.js",
  "bin": {
    "cluj-napoca-gtfs": "src/cli.js"
  },
  "scripts": {
    "build": "node src/cli.js build",
    "build:full": "npm run fetch:csv && npm run build",
    "validate": "node src/cli.js validate",
    "reconcile:dry": "node src/cli.js reconcile --dry-run",
    "fetch:csv": "node scripts/fetch-stage.js",
    "inspect:404s": "node scripts/inspect-404s.js",
    "smoke:trip-ids": "node src/verify-rt-parity.js",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "archiver": "^8.0.0"
  },
  "devDependencies": {
    "eslint": "^10.6.0",
    "vitest": "4.1.9"
  },
  "keywords": [
    "gtfs",
    "transit",
    "cluj-napoca",
    "ctp",
    "transitous",
    "tranzy",
    "reconciliation"
  ],
  "license": "MIT"
}
